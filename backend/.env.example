# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_gateway"
REDIS_URL="redis://localhost:6379"

# JWT signing secret. Min 32 bytes random. Sign access tokens (15 min TTL).
# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-32-chars-minimum-in-production"

# Master key for AES-256-GCM envelope encryption of UserProviderKey rows.
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=""
MASTER_KEY_ID="v1"

# Legacy admin key (X-Admin-Key header) — preserved for scripts/CI as a
# fallback; preferred admin auth is JWT with role=ADMIN.
ADMIN_API_KEY="adm_dev_key_change_in_production"

# Bootstrap admin account (used by seed.ts on fresh DB).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""

# Email (Sprint 1)
RESEND_API_KEY=""

# Server
PORT=3000
NODE_ENV=development

# CORS allowlist for production (comma-separated, no trailing slash).
# Leave empty for same-origin or non-browser deployments.
# Example: CORS_ORIGINS=https://app.raccoon.dev,https://staging.raccoon.dev
CORS_ORIGINS=

# Set to "true" when deployed behind a reverse proxy / load balancer
# (Railway, Fly, Render, k8s ingress, Vercel). Leave "false" in dev to
# prevent X-Forwarded-For spoofing against a local server.
TRUST_PROXY=false
